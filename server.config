{
    "server_id"                      : "VertAirComm",
    "server_ip"                      : "::",
    "public_host"                    : "vertserver-staging.up.railway.app",
    "server_sid"                     : 0,
    "server_port"                    : 9966,

    "enable_SSL"                     : false,
    "allow_fake_SSL"                 : true,

    "s2s_ws_target_ip"               : "AUTHENTICATOR_PRIVATE_HOST_HERE",
    "s2s_ws_target_port"             : "19001",

    "ignoreLoadingTasks"             : true,
    "allow_udpproxy_fixed_port"      : false,

    "ignoreLog"                      : true,
    "log_directory"                  : "./logs/",
    "log_timeZone"                   : "America/New_York",
    "log_detailed"                   : false,

    "ws_compression"                 : false,
    "memory_max"                     : 512
}
